{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NEO CITY Chunk Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "project",
    "section",
    "topic",
    "source_doc",
    "source_title",
    "status",
    "legal_sensitivity",
    "version",
    "text",
    "chunk_index"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "string",
      "const": "NEO CITY"
    },
    "section": {
      "type": "string",
      "enum": [
        "factsheet",
        "location_connectivity",
        "personas",
        "concept_positioning",
        "sales_strategy",
        "sales_policy",
        "legal",
        "pricing",
        "market",
        "price_sheet"
      ]
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "source_doc": {
      "type": "string",
      "minLength": 1
    },
    "source_title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "marketing_core",
        "strategy_data",
        "estimated",
        "hypothetical_policy",
        "legal_sensitive",
        "market_reference",
        "draft"
      ]
    },
    "legal_sensitivity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$"
    },
    "text": {
      "type": "string",
      "minLength": 1
    },
    "chunk_index": {
      "type": "integer",
      "minimum": 1
    }
  },
  "examples": [
    {
      "id": "neo_city_factsheet_001",
      "project": "NEO CITY",
      "section": "factsheet",
      "topic": "project_overview",
      "source_doc": "All database - NEO CITY.docx",
      "source_title": "FACTSHEET DỰ ÁN",
      "status": "estimated",
      "legal_sensitivity": "medium",
      "version": "2026-05",
      "text": "..."
    }
  ]
}
